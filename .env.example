# Set to true to use backend API (run: cd server && npm run dev)
VITE_USE_API=true
VITE_API_URL=http://localhost:3001/api

# --- Server (create server/.env or set when running) ---
# Firestore is the primary database. Set USE_FIRESTORE=false to use SQLite instead.
# FIREBASE_PROJECT_ID=casifly-14574
# Option 1: Path to service account JSON file
# GOOGLE_APPLICATION_CREDENTIALS=./firebase-service-account.json
# Option 2: Service account JSON as string (for serverless)
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"casifly-14574",...}
