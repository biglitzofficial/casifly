# Port (default: 3001)
PORT=3001

# Firestore (default: true). Set to false for SQLite.
USE_FIRESTORE=true

# Firebase project (optional, defaults to casifly-14574)
# FIREBASE_PROJECT_ID=your-project-id

# --- Choose ONE of these credential methods ---

# Option 1: Path to service account JSON file
# Place your *-firebase-adminsdk-*.json in the server folder and set:
# GOOGLE_APPLICATION_CREDENTIALS=./your-firebase-adminsdk-xxxxx.json

# Option 2: Service account JSON as string (for serverless / CI)
# FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"...","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"...","auth_provider_x509_cert_url":"...","client_x509_cert_url":"..."}

# JWT secret for auth tokens (change in production!)
# JWT_SECRET=your-secret-key
